# analytics.pocket.network — environment

# ── Data sources (mainnet indexer + Sauron LCD/RPC) ──
# Public: the live strip polls the indexer from the client.
NEXT_PUBLIC_GRAPHQL_URL=https://data.pocket.network/graphql
# Server-side only (params, fallback).
SAURON_LCD_URL=https://sauron-api.infra.pocket.network
SAURON_RPC_URL=https://sauron-rpc.infra.pocket.network
# Indexer-vs-RPC fallback threshold in blocks (public so the badge can evaluate lag client-side).
NEXT_PUBLIC_INDEXER_LAG_THRESHOLD=5

# ── Sibling explorer (for reward-issuance "drill to tx" link-outs) ──
NEXT_PUBLIC_EXPLORER_BASE_URL=https://explorer.pocket.network

# ── POKT price / market cap (CoinMarketCap) ──
# SERVER-SIDE ONLY. Never expose to the client. Provided by PNF.
CMC_API_KEY=

# ── Precompute (derived economics) ──
# Shared secret guarding the Vercel Cron route.
CRON_SECRET=
# Vercel Blob token (only if using the Blob storage backend for the precompute output).
BLOB_READ_WRITE_TOKEN=

# ── Dev only: vendor sync ──
# Path to the sibling explorer repo that lib/ + hooks/ vendored files are synced from.
EXPLORER_PATH=../../Explorer/pnf-explorer
